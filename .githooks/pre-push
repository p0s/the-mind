#!/bin/sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

commits_tmp=""

while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
  [ -z "${local_ref:-}" ] && continue
  case "${local_sha:-}" in
    ""|0000000000000000000000000000000000000000) continue ;;
  esac

  if [ "${remote_sha:-}" = "0000000000000000000000000000000000000000" ]; then
    new_commits="$(git rev-list "$local_sha" --not --remotes || true)"
  else
    new_commits="$(git rev-list "${remote_sha}..${local_sha}" || true)"
  fi

  if [ -n "$new_commits" ]; then
    commits_tmp="$commits_tmp
$new_commits"
  fi
done

unique_commits="$(printf '%s\n' "$commits_tmp" | awk 'NF && !seen[$0]++ {print $0}')"

if [ -z "$unique_commits" ]; then
  exit 0
fi

set --
for commit in $unique_commits; do
  set -- "$@" "$commit"
done

python3 scripts/check_public_repo_hygiene.py --commits "$@"

